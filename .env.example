DATABASE_URL=postgresql://media_scraper:media_scraper@localhost:5432/media_scraper
REDIS_URL=redis://localhost:6379
API_ACCESS_TOKEN=
API_HOST=0.0.0.0
API_PORT=3000
COOKIE_SECURE=false
PROFILE_DISCOVERY_CACHE_TTL_SECONDS=600
PROFILE_DISCOVERY_TIMEOUT_MS=45000
WEB_ORIGIN=http://localhost:5173
WEB_PORT=5173
API_PROXY_URL=http://localhost:3000
# Optional: interactive platform sign-in through a managed browser.
# BROWSERLESS_URL=http://localhost:3002
# BROWSERLESS_PUBLIC_URL=http://localhost:3002
# BROWSERLESS_TOKEN=
MEDIA_ROOT=./data/media
CREDENTIALS_ROOT=./data/credentials
# Optional override; when unset, collection concurrency is sized from CPU and memory.
# COLLECTION_CONCURRENCY=4
MAX_ASSET_BYTES=104857600
MAX_COLLECTION_BYTES=524288000
MAX_MEDIA_STORAGE_BYTES=4294967296
MEDIA_RETENTION_TRIGGER_PERCENT=80
MEDIA_RETENTION_TARGET_PERCENT=70
VIDEO_MAX_DIMENSION=1280
EXTRACTION_TIMEOUT_MS=1800000
OPTIMIZATION_TIMEOUT_MS=600000
METADATA_CONCURRENCY=4
MEDIA_STORAGE_DRIVER=local
